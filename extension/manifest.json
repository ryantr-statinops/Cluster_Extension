{
    "manifest_version": 3,
    "name": "Cluster Extension",
    "description": "A Chrome extension for managing clusters",
    "version": "1.0",
    "action" : {
        "default_popup": "popup/popup.html",
        "default_title": "Cluster Extension",
        "default_icon": {
        "16": "images/cluster_icon_16.png",
        "32": "images/cluster_icon_32.png",
        "48": "images/cluster_icon_48.png",
        "128": "images/cluster_icon_128.png"
    }

    },
    
    "icons": {
        "16": "images/cluster_icon_16.png",
        "32": "images/cluster_icon_32.png",
        "48": "images/cluster_icon_48.png",
        "128": "images/cluster_icon_128.png"
    },

    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ]
}